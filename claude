#!/usr/bin/env bash
# VeeCode Claude Gateway wrapper — see meta-repo docs/developer-setup.md.
# Routes Claude Code through the corporate gateway, attributing spend to the
# active gcloud identity. This file shadows the real `claude` binary.
#
# Self-resolving (no install-time templating): GATEWAY_URL comes from
# ~/.config/claude-gateway/config (bootstrapped on first run);
# REAL_CLAUDE is found at runtime by walking PATH; WRAPPER_VERSION is
# derived from the script's own sha256 so it's always content-accurate.
# What Pages serves is exactly what runs — no rendering step.
#
# Self-updating: once per UPDATE_CADENCE_S (24h, matching key TTL), curl
# Pages, sha256-compare to self, atomic-replace + re-exec on mismatch.
# Cache invalidation cascades: a wrapper-content change invalidates the
# cached virtual key (key_meta carries the wrapper's self-hash). Failures
# are fail-open — a Pages outage cannot brick `claude`.
set -eu

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude-gateway"
CONFIG_FILE="$CONFIG_DIR/config"
KEY_FILE="$CONFIG_DIR/key"
KEY_META="$CONFIG_DIR/key_meta"
LAST_CHECK_FILE="$CONFIG_DIR/last_check"

INSTALL_PATH="$HOME/.claude-gateway/bin/claude"
WRAPPER_URL="https://veecode-claude-gateway.github.io/claude"
DEFAULT_GATEWAY_URL="https://claude-gateway.vee.codes"
RUNBOOK_URL="https://github.com/veecode-claude-gateway/claude-gateway-parent/blob/main/docs/runbooks/"

UPDATE_CADENCE_S=$((24 * 60 * 60))
KEY_REFRESH_THRESHOLD_S=3600

mkdir -p "$CONFIG_DIR"

die() { printf 'claude-gateway: %s\n' "$*" >&2; exit 1; }
quiet() { [ -n "${CLAUDE_GATEWAY_QUIET:-}" ]; }

# ---- ANSI (only when stderr is a TTY and NO_COLOR isn't set) ----------
if [ -t 2 ] && [ -z "${NO_COLOR:-}" ]; then
  C_BOLD_CYAN=$'\033[1;36m'; C_DIM=$'\033[2m'; C_RESET=$'\033[0m'
else
  C_BOLD_CYAN=""; C_DIM=""; C_RESET=""
fi

# ---- portable sha256 (BSD shasum on macOS, GNU sha256sum on Linux) ----
sha256_stdin() {
  if command -v sha256sum >/dev/null 2>&1; then sha256sum | cut -d' ' -f1
  elif command -v shasum >/dev/null 2>&1; then shasum -a 256 | cut -d' ' -f1
  else return 1; fi
}
sha256_file() { sha256_stdin < "$1"; }

# ---- portable iso8601 → epoch -----------------------------------------
# /issue-key returns timestamps like "2026-05-08T13:00:54.258016+00:00".
# GNU date eats them directly. BSD date (macOS default) needs:
#   - fractional seconds removed (its %S has no fractional part)
#   - offset re-formatted from `+HH:MM` to `+HHMM` (its %z is +HHMM)
# Without the normalization, BSD date silently fails and we fall to 0,
# which makes the banner say "key expired" on a fresh key.
iso_to_epoch() {
  date -u -d "$1" +%s 2>/dev/null && return
  local norm
  norm=$(printf '%s' "$1" | sed -E 's/\.[0-9]+//; s/([+-])([0-9]{2}):([0-9]{2})$/\1\2\3/')
  date -u -j -f '%Y-%m-%dT%H:%M:%S%z' "$norm" +%s 2>/dev/null || echo 0
}

# ---- config: source if present, else bootstrap with default -----------
# The config file is plain `KEY="value"` lines, sourced as bash. Mode
# 600 by convention. Owner-managed: edit to override the gateway URL.
GATEWAY_URL="$DEFAULT_GATEWAY_URL"
if [ -r "$CONFIG_FILE" ]; then
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
else
  umask 077
  printf 'GATEWAY_URL="%s"\n' "$GATEWAY_URL" > "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"
fi

# ---- self-hash + wrapper version (content-derived) --------------------
SELF_HASH=$(sha256_file "$0" 2>/dev/null || echo "")
WRAPPER_VERSION="${SELF_HASH:0:7}"
[ -n "$WRAPPER_VERSION" ] || WRAPPER_VERSION="unknown"

# ---- resolve REAL_CLAUDE at runtime -----------------------------------
# Walk PATH, skip the wrapper's own install path, skip any other instance
# of the wrapper (identified by a marker in its header). This is the
# same logic install.sh uses, just lifted into the wrapper itself so
# there's no install-time bake-in.
resolve_real_claude() {
  local IFS=:
  local d candidate
  for d in $PATH; do
    [ -n "$d" ] || continue
    candidate="$d/claude"
    [ -x "$candidate" ] || continue
    [ "$candidate" = "$INSTALL_PATH" ] && continue
    head -n 5 "$candidate" 2>/dev/null | grep -q 'VeeCode Claude Gateway wrapper' && continue
    printf '%s' "$candidate"
    return 0
  done
  return 1
}

# ---- self-update (cadenced, fail-open) --------------------------------
# Compare sha256(self) vs sha256(latest from Pages). On mismatch,
# atomic-replace and re-exec. The downloaded script runs verbatim — no
# templating step here, no substitution-in-source bug class.
maybe_self_update() {
  [ -z "${CLAUDE_GATEWAY_NO_UPDATE:-}" ] || return 0

  local now last delta
  now=$(date -u +%s)
  last=$(cat "$LAST_CHECK_FILE" 2>/dev/null || echo 0)
  case "$last" in ''|*[!0-9]*) last=0 ;; esac
  delta=$((now - last))
  [ "$delta" -ge "$UPDATE_CADENCE_S" ] || return 0

  # Bump unconditionally so a Pages outage cannot cause hammering.
  printf '%s\n' "$now" > "$LAST_CHECK_FILE"

  local latest latest_hash
  latest=$(curl -fsSL --max-time 5 "$WRAPPER_URL" 2>/dev/null) || return 0
  [ -n "$latest" ] || return 0
  case "$latest" in
    '#!/usr/bin/env bash'*|'#!/bin/bash'*) : ;;
    *) return 0 ;;
  esac
  # Refuse to install a template that still has the pre-refactor
  # install-time at-at placeholders. Defense against accidentally
  # downgrading if Pages temporarily serves stale content. Pattern is
  # assembled via concat so this source file doesn't itself contain
  # the literal token (which would self-DoS the guard the moment it
  # runs against a fresh copy of itself).
  local poison_re
  poison_re='@@''(GATEWAY_URL|REAL_CLAUDE|WRAPPER_VERSION)''@@'
  if printf '%s' "$latest" | grep -qE "$poison_re"; then
    return 0
  fi

  latest_hash=$(printf '%s' "$latest" | sha256_stdin) || return 0
  [ "$latest_hash" != "$SELF_HASH" ] || return 0

  local tmpfile
  tmpfile=$(mktemp -t claude-gateway-update.XXXXXX) || return 0
  printf '%s' "$latest" > "$tmpfile"
  chmod 755 "$tmpfile"

  cp "$INSTALL_PATH" "$INSTALL_PATH.prev" 2>/dev/null || true
  if ! mv "$tmpfile" "$INSTALL_PATH" 2>/dev/null; then
    rm -f "$tmpfile"
    return 0
  fi

  if ! quiet && [ -t 2 ]; then
    printf '%s· wrapper updated (%s → %s)%s\n' \
      "$C_DIM" "${SELF_HASH:0:7}" "${latest_hash:0:7}" "$C_RESET" >&2
  fi

  exec "$0" "$@"
}

maybe_self_update "$@"

REAL_CLAUDE=$(resolve_real_claude) \
  || die "could not find a real 'claude' binary on PATH (excluding the wrapper). Install Claude Code: https://docs.claude.com/en/docs/claude-code"

# ---- key-cache load ---------------------------------------------------
now=$(date -u +%s)
key=""; expires_at_epoch=0; exp_iso=""
if [ -r "$KEY_FILE" ]; then
  key=$(sed -n '1p' "$KEY_FILE" 2>/dev/null || true)
  exp_iso=$(sed -n '2p' "$KEY_FILE" 2>/dev/null || true)
  [ -n "${exp_iso:-}" ] && expires_at_epoch=$(iso_to_epoch "$exp_iso")
fi

# ---- invalidate cached key if minted under a different wrapper --------
# Cheap, deterministic invalidation: when this script's content changes
# (manual re-install OR self-update above), the cached key may have been
# minted under assumptions the new code doesn't share (env-var rename,
# header rename, etc.). Re-mint instead of using a key the new code
# wouldn't have produced.
key_meta=$(cat "$KEY_META" 2>/dev/null || echo "")
if [ -n "$SELF_HASH" ] && [ -n "$key_meta" ] && [ "$key_meta" != "$SELF_HASH" ]; then
  key=""
fi

# ---- mint or refresh --------------------------------------------------
if [ -z "$key" ] || [ "$((expires_at_epoch - now))" -lt "$KEY_REFRESH_THRESHOLD_S" ]; then
  command -v gcloud >/dev/null 2>&1 \
    || die "gcloud not found on PATH. Install + 'gcloud auth login'. See ${RUNBOOK_URL}."
  token=$(gcloud auth print-access-token 2>/dev/null) \
    || die "'gcloud auth print-access-token' failed. Run 'gcloud auth login'."
  tmp=$(mktemp -t claude-gateway.XXXXXX) || die "mktemp failed"
  http_code=$(curl -sS -o "$tmp" -w '%{http_code}' --max-time 10 \
      -X POST "$GATEWAY_URL/issue-key" \
      -H "Authorization: Bearer $token" \
      -H "Content-Type: application/json" -d '{}') || {
    rm -f "$tmp"
    die "could not reach gateway at $GATEWAY_URL (network/DNS/TLS failure). See ${RUNBOOK_URL}."
  }
  resp=$(cat "$tmp"); rm -f "$tmp"
  case "$http_code" in
    2*) : ;;
    401|403) die "gateway rejected your identity ($http_code): $resp. Run 'gcloud auth login' if your token has expired." ;;
    5*)      die "gateway error $http_code from /issue-key: $resp. See ${RUNBOOK_URL}." ;;
    *)       die "unexpected gateway response $http_code: $resp" ;;
  esac
  key=$(printf '%s' "$resp" | sed -n 's/.*"key"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
  exp_iso=$(printf '%s' "$resp" | sed -n 's/.*"expires_at"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
  [ -n "$key" ] || die "gateway response missing 'key': $resp"
  umask 077
  printf '%s\n%s\n' "$key" "$exp_iso" > "$KEY_FILE"
  chmod 600 "$KEY_FILE"
  [ -n "$SELF_HASH" ] && printf '%s\n' "$SELF_HASH" > "$KEY_META"
  expires_at_epoch=$(iso_to_epoch "$exp_iso")
fi

# ---- banner (stderr only, ≤2 lines, suppressible) ---------------------
# Always-on by design: pilot users routinely forget they're routed
# through a gateway, then mis-attribute weird behaviour to Anthropic.
# Set CLAUDE_GATEWAY_QUIET=1 to suppress.
if [ -t 2 ] && ! quiet; then
  identity=$(gcloud config get-value account 2>/dev/null | head -1 || true)
  [ -n "$identity" ] || identity="(no gcloud account)"

  secs_left=$((expires_at_epoch - now))
  if [ "$secs_left" -le 0 ]; then key_state="expired"
  elif [ "$secs_left" -ge 3600 ]; then key_state="$((secs_left / 3600))h left"
  else key_state="$((secs_left / 60))m left"
  fi

  last=$(cat "$LAST_CHECK_FILE" 2>/dev/null || echo 0)
  case "$last" in ''|*[!0-9]*) last=0 ;; esac
  since=$((now - last))
  if [ "$last" -eq 0 ]; then checked="never"
  elif [ "$since" -ge 3600 ]; then checked="$((since / 3600))h ago"
  elif [ "$since" -ge 60 ]; then checked="$((since / 60))m ago"
  else checked="just now"
  fi

  gw_host=${GATEWAY_URL#http*://}
  printf '%s▰ Claude Gateway%s · %s\n' "$C_BOLD_CYAN" "$C_RESET" "$identity" >&2
  printf '%s  key %s · wrapper %s (checked %s) · via %s%s\n' \
    "$C_DIM" "$key_state" "$WRAPPER_VERSION" "$checked" "$gw_host" "$C_RESET" >&2
fi

# ---- exec the real claude ---------------------------------------------
export ANTHROPIC_BASE_URL="$GATEWAY_URL"
export ANTHROPIC_AUTH_TOKEN="$key"
unset ANTHROPIC_API_KEY
export CLAUDE_CONFIG_DIR="$CONFIG_DIR/claude"
export ANTHROPIC_CUSTOM_HEADERS="x-claude-gateway-cli: $WRAPPER_VERSION"
mkdir -p "$CLAUDE_CONFIG_DIR"

exec "$REAL_CLAUDE" "$@"
